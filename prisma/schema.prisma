generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  subdomain    String   @unique
  customDomain String?  @unique
  data         Json
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}